          <geometry><box><size>0.5 0.5 3.0</size></box></geometry>
          <material><ambient>0.55 0.55 0.55 1</ambient><diffuse>0.55 0.55 0.55 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- 障碍 2: 圆柱  r≈4.7m, θ=55°  radius=0.35m h=2.5m -->
