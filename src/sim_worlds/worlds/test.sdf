    <!-- ============================================================
         随机几何障碍  (10 个)
         中心 3m 半径内无障碍；障碍分布在 r ≈ 4~7.5m 环形区
         ---- 调整方法 ------------------------------------------------
         <pose> X Y Z  0 0 YAW </pose>
           X, Y : 障碍中心水平位置 (m)
           Z    : 半高 = 障碍高度/2
           YAW  : 绕 Z 轴旋转 (rad)
         box  <size> LX LY LZ </size>  → LX,LY=截面, LZ=高度
         cylinder  <radius> <length>   → radius=半径, length=高度
         ============================================================ -->

    <!-- 障碍 1: 方柱  r≈4.0m, θ=0°  尺寸 0.5×0.5×3.0m -->
    <model name="obs_box_0">
      <static>true</static>
      <pose>4.0 0.0 1.5 0 0 0</pose>
      <link name="link">
        <collision name="c"><geometry><box><size>0.5 0.5 3.0</size></box></geometry></collision>
        <visual name="v">
          <geometry><box><size>0.5 0.5 3.0</size></box></geometry>
          <material><ambient>0.55 0.55 0.55 1</ambient><diffuse>0.55 0.55 0.55 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- 障碍 2: 圆柱  r≈4.7m, θ=55°  radius=0.35m h=2.5m -->
    <model name="obs_cyl_0">
      <static>true</static>
      <pose>2.7 3.8 1.25 0 0 0</pose>
      <link name="link">
        <collision name="c"><geometry><cylinder><radius>0.35</radius><length>2.5</length></cylinder></geometry></collision>
        <visual name="v">
          <geometry><cylinder><radius>0.35</radius><length>2.5</length></cylinder></geometry>
          <material><ambient>0.7 0.4 0.1 1</ambient><diffuse>0.7 0.4 0.1 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- 障碍 3: 方墩 box  r≈3.7m, θ=110°  尺寸 0.8×0.8×2.0m -->
